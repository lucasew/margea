# Required environment variables for Margea dev server and production.
#
# Copy this file and fill the values:
#   cp .env.example .env.local
#
# .env.local is git-ignored (thanks to *.local in .gitignore).
#
# Astro will automatically load .env*, .env.local, .env.development etc.
# Because we declare a schema in astro.config.mjs, `astro dev` (and `mise dev`)
# will fail fast with a clear error message if any required variable is missing.
#
# Never commit real secrets. For production, set the same variables in your
# Vercel project settings (or whatever platform you deploy to).

# GitHub OAuth App credentials
# 1. Go to https://github.com/settings/developers → OAuth Apps → New OAuth App
# 2. For local development use a separate app (recommended):
#      - Homepage URL: http://localhost:3000
#      - Authorization callback URL: http://localhost:3000/api/auth/callback
#    The callback URL registered in GitHub MUST exactly match GITHUB_CALLBACK_URL.
# 3. After creating, copy the Client ID and generate a Client Secret.

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# The public URL that GitHub will redirect back to after the user authorizes.
# For local dev (with the port we force in astro.config):
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/callback

# Long random secret used to sign session JWTs (HttpOnly cookie).
# Generate a strong one with:
#   openssl rand -hex 32
# or
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Keep this the same between restarts if you want sessions to survive dev server restarts.
SESSION_SECRET=
